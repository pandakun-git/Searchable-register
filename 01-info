(() => {
  "use strict";

  const CONFIG = {
    LIST_LABEL: "人給給与（会計）業務Ｑ＆Ａ",
    LIST_NOTE: "中継JSONを参照",
    JSON_URL: "./info-search-data.json",
    PAGE_SIZE: 15
  };

  const state = {
    allItems: [],
    filteredItems: [],
    selectedId: null,
    keywords: [],
    currentPage: 1,
    generatedAt: ""
  };

  document.addEventListener("DOMContentLoaded", async () => {
    bindEvents();
    renderStaticMeta();
    await init();
  });

  function bindEvents() {
    document.getElementById("searchBtn").addEventListener("click", applySearch);
    document.getElementById("clearBtn").addEventListener("click", clearSearch);
    document.getElementById("keywordInput").addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        applySearch();
      }
    });
  }

  function renderStaticMeta() {
    document.getElementById("targetListName").textContent = CONFIG.LIST_LABEL;
    document.getElementById("targetListNote").textContent = CONFIG.LIST_NOTE;
  }

  async function init() {
    try {
      setError("");
      setStatus("JSON読込中...");

      const res = await fetch(`${CONFIG.JSON_URL}?t=${Date.now()}`, {
        method: "GET",
        cache: "no-store",
        credentials: "same-origin"
      });

      if (!res.ok) {
        throw new Error(`JSON HTTP ${res.status}`);
      }

      const data = await res.json();

      state.allItems = Array.isArray(data.items) ? data.items : [];
      state.filteredItems = [...state.allItems];
      state.generatedAt = data.generatedAt || "";
      state.currentPage = 1;

      syncSelectedToCurrentPage(true);
      renderAll();

      setStatus(state.generatedAt ? `読込完了 / 最終同期: ${state.generatedAt}` : "読込完了");
    } catch (err) {
      console.error(err);
      state.allItems = [];
      state.filteredItems = [];
      state.selectedId = null;
      renderAll();
      setStatus("");
      setError("読込失敗: " + err.message);
    }
  }

  function applySearch() {
    const input = document.getElementById("keywordInput").value.trim();
    const words = input
      .split(/\s+/)
      .map((w) => w.trim().toLowerCase())
      .filter(Boolean);

    state.keywords = words;
    state.currentPage = 1;

    if (!words.length) {
      state.filteredItems = [...state.allItems];
      syncSelectedToCurrentPage(true);
      renderAll();
      setError("");
      setStatus(state.generatedAt ? `全件表示 / 最終同期: ${state.generatedAt}` : "全件表示");
      return;
    }

    state.filteredItems = state.allItems.filter((item) => {
      const source = [
        item.title,
        item.businessCategory,
        item.actorCategory,
        item.operatorStaffNo,
        item.targetStaffNo,
        item.manualPage,
        item.body,
        item.directionCategory,
        item.unitName,
        item.rankName,
        item.extensionNo,
        item.answer,
        item.situation,
        item.batchId
      ]
        .join(" ")
        .toLowerCase();

      return words.every((word) => source.includes(word));
    });

    syncSelectedToCurrentPage(true);
    renderAll();
    setError("");
    setStatus(state.generatedAt ? `検索完了 / 最終同期: ${state.generatedAt}` : "検索完了");
  }

  function clearSearch() {
    document.getElementById("keywordInput").value = "";
    state.keywords = [];
    state.filteredItems = [...state.allItems];
    state.currentPage = 1;
    state.selectedId = null;

    syncSelectedToCurrentPage(true);
    renderAll();
    setError("");
    setStatus(state.generatedAt ? `検索条件をクリアしました / 最終同期: ${state.generatedAt}` : "検索条件をクリアしました");
  }

  function renderAll() {
    renderList();
    renderPager();
    renderDetail();
    renderPageMeta();
  }

  function renderList() {
    const listArea = document.getElementById("listArea");
    const pageItems = getPageItems();

    document.getElementById("resultCount").textContent = state.filteredItems.length;

    if (!state.filteredItems.length) {
      listArea.innerHTML = `
        <div class="empty-box">
          該当する情報はありません。<br />
          キーワードを変えて再度検索してください。
        </div>
      `;
      return;
    }

    listArea.innerHTML = pageItems.map((item) => {
      const selectedClass = item.id === state.selectedId ? "selected" : "";
      const previewSource = item.body || item.answer || item.manualPage || "";
      const preview = shorten(previewSource, 90);

      return `
        <div class="list-item ${selectedClass}" data-id="${item.id}">
          <div class="item-title">${highlightPlainText(escapeHtml(item.title || "(タイトルなし)"), state.keywords)}</div>

          <div class="chips">
            ${item.businessCategory ? `<span class="chip">${escapeHtml(item.businessCategory)}</span>` : ""}
            ${item.actorCategory ? `<span class="chip">${escapeHtml(item.actorCategory)}</span>` : ""}
            ${item.situation ? `<span class="chip">${escapeHtml(item.situation)}</span>` : ""}
          </div>

          <div class="item-preview">
            ${highlightPlainText(escapeHtml(preview), state.keywords)}
          </div>

          <div class="item-footer">
            <span>${item.unitName ? "部隊等名: " + escapeHtml(item.unitName) : ""}</span>
            <span>更新日: ${formatDate(item.modified)}</span>
          </div>
        </div>
      `;
    }).join("");

    listArea.querySelectorAll(".list-item").forEach((el) => {
      el.addEventListener("click", () => {
        state.selectedId = Number(el.dataset.id);
        renderList();
        renderDetail();
      });
    });
  }

  function renderPager() {
    const pagerArea = document.getElementById("pagerArea");
    const totalPages = getTotalPages();

    if (!state.filteredItems.length || totalPages <= 1) {
      pagerArea.innerHTML = "";
      return;
    }

    const tokens = buildPageTokens(state.currentPage, totalPages);
    const html = [
      `<button type="button" class="pager-btn" data-page="${state.currentPage - 1}" ${state.currentPage <= 1 ? "disabled" : ""}>前へ</button>`
    ];

    tokens.forEach((token) => {
      if (token === "...") {
        html.push(`<span class="pager-ellipsis">…</span>`);
        return;
      }

      const activeClass = token === state.currentPage ? "active" : "";
      html.push(`<button type="button" class="pager-btn ${activeClass}" data-page="${token}">${token}</button>`);
    });

    html.push(
      `<button type="button" class="pager-btn" data-page="${state.currentPage + 1}" ${state.currentPage >= totalPages ? "disabled" : ""}>次へ</button>`
    );

    pagerArea.innerHTML = html.join("");

    pagerArea.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => {
        changePage(Number(btn.dataset.page));
      });
    });
  }

  function renderPageMeta() {
    const total = state.filteredItems.length;
    const totalPages = getTotalPages();

    if (!total) {
      document.getElementById("pageSummary").textContent = "0 件";
      document.getElementById("pageInfo").textContent = "0 / 0 ページ";
      return;
    }

    const start = (state.currentPage - 1) * CONFIG.PAGE_SIZE + 1;
    const end = Math.min(start + CONFIG.PAGE_SIZE - 1, total);

    document.getElementById("pageSummary").textContent = `${start} - ${end} / ${total} 件`;
    document.getElementById("pageInfo").textContent = `${state.currentPage} / ${totalPages} ページ`;
  }

  function renderDetail() {
    const detailArea = document.getElementById("detailArea");
    const item = state.filteredItems.find((x) => x.id === state.selectedId);

    if (!item) {
      detailArea.innerHTML = `
        <div class="placeholder">
          左の一覧からデータを選択すると、<br />
          詳細内容がここに表示されます。
        </div>
      `;
      return;
    }

    detailArea.innerHTML = `
      <h2 class="detail-title">${highlightPlainText(escapeHtml(item.title || "(タイトルなし)"), state.keywords)}</h2>

      <div class="detail-grid">
        ${renderGridRow("業務区分", item.businessCategory)}
        ${renderGridRow("アクター区分", item.actorCategory)}
        ${renderGridRow("方面等区分", item.directionCategory)}
        ${renderGridRow("部隊等名", item.unitName)}
        ${renderGridRow("氏階級", item.rankName)}
        ${renderGridRow("職員番号（操作者）", item.operatorStaffNo)}
        ${renderGridRow("職員番号（該当者）", item.targetStaffNo)}
        ${renderGridRow("内線番号", item.extensionNo)}
        ${renderGridRow("マニュアルページ", item.manualPage)}
        ${renderGridRow("状況", item.situation)}
        ${renderGridRow("バッチID", item.batchId)}
        ${renderGridRow("更新日", formatDate(item.modified))}
      </div>

      <div class="detail-section">
        <h3>本文</h3>
        <div class="detail-box">${formatRichText(item.body, state.keywords)}</div>
      </div>

      <div class="detail-section">
        <h3>回答</h3>
        <div class="detail-box">${formatRichText(item.answer, state.keywords)}</div>
      </div>
    `;
  }

  function renderGridRow(label, value) {
    return `
      <div class="detail-label">${escapeHtml(label)}</div>
      <div class="detail-value">${formatRichText(value, state.keywords)}</div>
    `;
  }

  function changePage(page) {
    const totalPages = getTotalPages();
    if (!totalPages) return;

    const nextPage = Math.min(Math.max(page, 1), totalPages);
    if (nextPage === state.currentPage) return;

    state.currentPage = nextPage;
    syncSelectedToCurrentPage(false);
    renderAll();
  }

  function syncSelectedToCurrentPage(forceFirst) {
    const pageItems = getPageItems();

    if (!pageItems.length) {
      state.selectedId = null;
      return;
    }

    const existsOnPage = pageItems.some((item) => item.id === state.selectedId);

    if (forceFirst || !existsOnPage) {
      state.selectedId = pageItems[0].id;
    }
  }

  function getPageItems() {
    if (!state.filteredItems.length) return [];

    const totalPages = getTotalPages();
    if (state.currentPage > totalPages) state.currentPage = totalPages;
    if (state.currentPage < 1) state.currentPage = 1;

    const startIndex = (state.currentPage - 1) * CONFIG.PAGE_SIZE;
    const endIndex = startIndex + CONFIG.PAGE_SIZE;
    return state.filteredItems.slice(startIndex, endIndex);
  }

  function getTotalPages() {
    if (!state.filteredItems.length) return 0;
    return Math.ceil(state.filteredItems.length / CONFIG.PAGE_SIZE);
  }

  function buildPageTokens(current, total) {
    if (total <= 7) {
      return Array.from({ length: total }, (_, i) => i + 1);
    }

    const tokens = [1];
    const start = Math.max(2, current - 1);
    const end = Math.min(total - 1, current + 1);

    if (start > 2) tokens.push("...");
    for (let i = start; i <= end; i += 1) tokens.push(i);
    if (end < total - 1) tokens.push("...");
    tokens.push(total);

    return tokens;
  }

  function formatRichText(value, keywords) {
    const text = String(value || "").trim();
    if (!text) return "—";

    const parts = splitTextAndUrls(text);

    return parts.map((part) => {
      if (part.type === "url") {
        const safeUrl = escapeHtml(part.value);
        return `<a href="${safeUrl}" target="_blank" rel="noopener noreferrer">${safeUrl}</a>`;
      }
      return highlightPlainText(escapeHtml(part.value), keywords);
    }).join("");
  }

  function splitTextAndUrls(text) {
    const regex = /(https?:\/\/[^\s]+)/gi;
    const parts = [];
    let lastIndex = 0;
    let match;

    while ((match = regex.exec(text)) !== null) {
      if (match.index > lastIndex) {
        parts.push({ type: "text", value: text.slice(lastIndex, match.index) });
      }
      parts.push({ type: "url", value: match[0] });
      lastIndex = regex.lastIndex;
    }

    if (lastIndex < text.length) {
      parts.push({ type: "text", value: text.slice(lastIndex) });
    }

    return parts;
  }

  function shorten(text, maxLength) {
    if (!text) return "";
    return text.length > maxLength ? `${text.slice(0, maxLength)} ...` : text;
  }

  function formatDate(value) {
    if (!value) return "—";

    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return value;

    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    const hh = String(d.getHours()).padStart(2, "0");
    const mm = String(d.getMinutes()).padStart(2, "0");

    return `${y}/${m}/${day} ${hh}:${mm}`;
  }

  function setStatus(text) {
    document.getElementById("statusText").textContent = text || "";
  }

  function setError(text) {
    document.getElementById("errorText").textContent = text || "";
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function escapeRegExp(value) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  function highlightPlainText(escapedText, keywords) {
    if (!keywords || !keywords.length) return escapedText;

    let result = escapedText;

    [...keywords]
      .filter(Boolean)
      .sort((a, b) => b.length - a.length)
      .forEach((word) => {
        const re = new RegExp(`(${escapeRegExp(word)})`, "gi");
        result = result.replace(re, "<mark>$1</mark>");
      });

    return result;
  }
})();
