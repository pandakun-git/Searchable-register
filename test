<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>SharePoint接続テスト</title>
</head>
<body>
  <h1>SharePoint接続テスト</h1>
  <pre id="log">開始前</pre>

<script>
(function () {
  var log = document.getElementById("log");

  function write(msg) {
    log.textContent += "\n" + msg;
  }

  function getJson(url, callback) {
    write("アクセス中:");
    write(url);

    var xhr = new XMLHttpRequest();
    xhr.open("GET", url, true);
    xhr.withCredentials = true;
    xhr.setRequestHeader("Accept", "application/json;odata=verbose");

    xhr.onreadystatechange = function () {
      if (xhr.readyState === 4) {
        write("HTTP status: " + xhr.status);

        if (xhr.status >= 200 && xhr.status < 300) {
          callback(null, JSON.parse(xhr.responseText));
        } else {
          write("エラー本文:");
          write(xhr.responseText.substring(0, 1000));
          callback(new Error("HTTP " + xhr.status), null);
        }
      }
    };

    xhr.send();
  }

  try {
    log.textContent = "JS起動OK";

    var WEB_URL = "https://cc-n.gbase.gsdf.mod.go.jp/cc/jinkyu/kyuyokaikei";
    var LIST_URL = "/cc/jinkyu/kyuyokaikei/Lists/List1";

    var listInfoUrl =
      WEB_URL + "/_api/web/GetList('" + LIST_URL.replace(/'/g, "''") + "')" +
      "?$select=Title,ItemCount";

    getJson(listInfoUrl, function (err, data) {
      if (err) {
        write("=== ERROR ===");
        write(err.message);
        return;
      }

      write("リスト接続OK");
      write("リスト名: " + data.d.Title);
      write("件数: " + data.d.ItemCount);

      var itemUrl =
        WEB_URL + "/_api/web/GetList('" + LIST_URL.replace(/'/g, "''") + "')" +
        "/items?$top=1&$select=Id,Title,Modified";

      getJson(itemUrl, function (err2, itemData) {
        if (err2) {
          write("=== ERROR ===");
          write(err2.message);
          return;
        }

        write("アイテム取得OK");
        write("取得件数: " + itemData.d.results.length);

        if (itemData.d.results.length > 0) {
          write("先頭タイトル: " + itemData.d.results[0].Title);
        }

        write("=== SUCCESS ===");
      });
    });
  } catch (e) {
    write("=== ERROR ===");
    write(e.message);
  }
})();
</script>
</body>
</html>
